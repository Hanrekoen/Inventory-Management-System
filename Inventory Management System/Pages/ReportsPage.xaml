<Page x:Class="Inventory_Management_System.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Inventory_Management_System.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReportsPage">

    <Grid Background="#F5F5F5" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Charts -->
            <RowDefinition Height="Auto"/>
            <!-- Export Buttons -->
        </Grid.RowDefinitions>

        <!-- Charts Section -->
        <TabControl Grid.Row="0" Margin="10">
            <TabItem Header="Monthly Sales Trends">
                <!-- Replace with chart control (e.g., LiveCharts/OxyPlot) -->
                <TextBlock Text="Monthly Sales Chart Placeholder" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </TabItem>
            <TabItem Header="Stock Levels">
                <TextBlock Text="Stock Levels Chart Placeholder" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </TabItem>
            <TabItem Header="Supplier Contributions">
                <TextBlock Text="Supplier Contributions Chart Placeholder" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </TabItem>
        </TabControl>

        <!-- Export Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Export to PDF" Width="150" Command="{Binding ExportPdfCommand}" Margin="5"/>
            <Button Content="Export to Excel" Width="150" Command="{Binding ExportExcelCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
