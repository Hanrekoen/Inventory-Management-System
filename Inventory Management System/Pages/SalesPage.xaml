<Page x:Class="Inventory_Management_System.Pages.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Inventory_Management_System.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SalesPage">

    <Grid Background="#F5F5F5" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- New Sale Form -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- Sales History -->
        </Grid.RowDefinitions>

        <!-- Record New Sale -->
        <GroupBox Header="Record New Sale" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical" Margin="10">
                <ComboBox ItemsSource="{Binding Products}" 
                          DisplayMemberPath="ProductName" 
                          SelectedItem="{Binding SelectedProduct}" 
                          Width="250" Margin="0,0,0,10"/>
                <TextBox Text="{Binding QuantitySold}" Width="100" Margin="0,0,0,10"/>
                <DatePicker SelectedDate="{Binding SaleDate}" Width="200" Margin="0,0,0,10"/>
                <Button Content="Save Sale" Width="120" Command="{Binding AddSaleCommand}"/>
            </StackPanel>
        </GroupBox>

        <!-- Filters -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <DatePicker SelectedDate="{Binding StartDate}" Width="150" Margin="5"/>
            <DatePicker SelectedDate="{Binding EndDate}" Width="150" Margin="5"/>
            <ComboBox ItemsSource="{Binding Products}" DisplayMemberPath="ProductName" 
                      SelectedItem="{Binding FilterProduct}" Width="200" Margin="5"/>
            <Button Content="Apply Filter" Command="{Binding FilterSalesCommand}" Width="120"/>
        </StackPanel>

        <!-- Sales History -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding SalesHistory}" AutoGenerateColumns="False" Margin="10"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="200"/>
                <DataGridTextColumn Header="Quantity" Binding="{Binding QuantitySold}" Width="100"/>
                <DataGridTextColumn Header="Date" Binding="{Binding SaleDate}" Width="150"/>
                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
