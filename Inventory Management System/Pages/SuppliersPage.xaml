<Page x:Class="Inventory_Management_System.Pages.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Inventory_Management_System.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SuppliersPage">

    <Grid Background="#F5F5F5" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox Width="300" Height="30" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
            <Button Content="Search" Width="100" Height="30" Command="{Binding SearchCommand}"/>
        </StackPanel>

        <!-- Suppliers ListView -->
        <ListView Grid.Row="1" ItemsSource="{Binding Suppliers}" Margin="10" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Supplier Name" DisplayMemberBinding="{Binding SupplierName}" Width="200"/>
                    <GridViewColumn Header="Contact Info" DisplayMemberBinding="{Binding ContactName}" Width="200"/>
                    <GridViewColumn Header="Phone" DisplayMemberBinding="{Binding Phone}" Width="150"/>
                    <GridViewColumn Header="Products Supplied" DisplayMemberBinding="{Binding ProductsSupplied}" Width="250"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Add Supplier" Width="120" Height="40" Margin="5" Command="{Binding AddSupplierCommand}"/>
            <Button Content="Edit Supplier" Width="120" Height="40" Margin="5" Command="{Binding EditSupplierCommand}"/>
            <Button Content="Remove Supplier" Width="120" Height="40" Margin="5" Command="{Binding RemoveSupplierCommand}"/>
        </StackPanel>
    </Grid>
</Page>
