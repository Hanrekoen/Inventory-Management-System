<Window x:Class="Inventory_Management_System.ProductsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inventory_Management_System"
        mc:Ignorable="d"
        Title="Products" Height="600" Width="900">
    <Grid Background="#F5F5F5" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Search bar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox Width="300" Height="30" Margin="0,0,10,0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" ToolTip="Search Products by name or category" />
            <Button Content="Search" Width="100" Height="30" Command="{Binding SearchCommand}" />
        </StackPanel>

        <!-- Products DataGrid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Products}" 
                  AutoGenerateColumns="False" SelectionMode="Single"
                  IsReadOnly="True" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID" Binding="{Binding ProductID}" Width="100"/>
                <DataGridTextColumn Header="Name" Binding="{Binding ProductName}" Width="200"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=C}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>


        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Add Product" Width="120" Height="40" Margin="5" Command="{Binding AddProductCommand}"/>
            <Button Content="Edit Product" Width="120" Height="40" Margin="5" Command="{Binding EditProductCommand}"/>
            <Button Content="Delete Product" Width="120" Height="40" Margin="5" Command="{Binding DeleteProductCommand}"/>
        </StackPanel>
    </Grid>
</Window>
